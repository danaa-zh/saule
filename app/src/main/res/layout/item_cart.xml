<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_product_card"
    android:padding="12dp">

    <ImageView
        android:id="@+id/productImage"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:background="@drawable/bg_chip_default"
        android:contentDescription="Product image"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/productName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:textColor="@color/textPrimary"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/deleteBtn"
        app:layout_constraintStart_toEndOf="@id/productImage"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Nike Air Max 90 White Shoes" />

    <TextView
        android:id="@+id/colorTv"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="4dp"
        android:textColor="@color/textSecondary"
        android:textSize="12sp"
        app:layout_constraintEnd_toStartOf="@id/deleteBtn"
        app:layout_constraintStart_toEndOf="@id/productImage"
        app:layout_constraintTop_toBottomOf="@id/productName"
        tools:text="Color: White" />

    <TextView
        android:id="@+id/priceTv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="4dp"
        android:textColor="@color/purple"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@id/productImage"
        app:layout_constraintTop_toBottomOf="@id/colorTv"
        tools:text="15 000 ₸" />

    <ImageButton
        android:id="@+id/deleteBtn"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@drawable/bg_chip_default"
        android:contentDescription="Remove from cart"
        android:padding="7dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/ic_minus"
        app:tint="@color/error" />

    <LinearLayout
        android:id="@+id/quantityRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/decreaseBtn"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:background="@drawable/bg_quantity_selector"
            android:contentDescription="Decrease"
            android:padding="7dp"
            app:srcCompat="@drawable/ic_minus" />

        <TextView
            android:id="@+id/quantityTv"
            android:layout_width="36dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/textPrimary"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="2" />

        <ImageView
            android:id="@+id/increaseBtn"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:background="@drawable/bg_quantity_selector"
            android:contentDescription="Increase"
            android:padding="7dp"
            app:srcCompat="@drawable/ic_plus" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>